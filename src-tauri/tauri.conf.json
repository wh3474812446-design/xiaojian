{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "小剪",
  "version": "1.0.0",
  "identifier": "com.wanghan.clipboardenhancer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "main.html",
        "title": "小剪",
        "width": 560,
        "height": 720,
        "minWidth": 480,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "transparent": true,
        "decorations": false
      },
      {
        "label": "panel",
        "url": "panel.html",
        "width": 480,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
